---
import Layout from '../layouts/Layout.astro';

const experiments = [
  {
    title: "Page A: Traditional SEO Test",
    desc: "Targeting 'Java AI Agents' with 2010-style keyword optimization.",
    url: "/java-ai-agents",
    tag: "SEO"
  },
  {
    title: "Page B: GEO Specialist Guide",
    desc: "Optimized for AI retrieval using AnswerCapsules and Schema.org.",
    url: "/langchain4j-workflows",
    tag: "GEO"
  },
  {
    title: "Article 3: Comparison Test",
    desc: "LangChain4j vs Spring AI head-to-head for AI model citations.",
    url: "/langchain4j-vs-spring-ai",
    tag: "GEO"
  },
  {
    title: "Article 4: Memory Fix Guide",
    desc: "How to fix 'context window exceeded' errors in LangChain4j agents.",
    url: "/langchain4j-memory-fix",
    tag: "GEO"
  }
];

// JSON-LD for the Index Page
const homeSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Ben's AI Lab",
      "url": "https://seo-lab-one.vercel.app/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://seo-lab-one.vercel.app/?s={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://seo-lab-one.vercel.app/#collection",
      "name": "Java SEO & GEO Experiments",
      "description": "Technical lab testing LangChain4j and Java AI agent optimizations.",
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": experiments.map((exp, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "url": `https://seo-lab-one.vercel.app${exp.url}`,
          "name": exp.title
        }))
      }
    }
  ]
});
---

<Layout 
  title="Ben's AI Lab | Java SEO & GEO Experiments"
  description="Testing the intersection of Traditional Search and Generative AI Optimization for Java developers."
  schema={homeSchema}
>
    <main>
        <header>
            <h1>🧪 The Java AI Lab</h1>
            <p>Testing the intersection of <strong>Traditional Search</strong> and <strong>Generative AI Optimization</strong>.</p>
        </header>

        <section class="experiment-grid" aria-label="Active Experiments">
            {experiments.map((exp) => (
                <article class="card">
                    <span class="badge">{exp.tag}</span>
                    <h2>{exp.title}</h2>
                    <p>{exp.desc}</p>
                    <a href={exp.url} class="button" aria-label={`Read ${exp.title}`}>View Experiment →</a>
                </article>
            ))}
        </section>

        <footer class="bot-links">
            <p>Crawler Resources: 
                <a href="/robots.txt">robots.txt</a> | 
                <a href="/llms.txt">llms.txt</a> | 
                <a href="/sitemap-index.xml">Sitemap</a>
            </p>
        </footer>
    </main>
</Layout>

<style>
    /* Your existing styles are fine, but consider adding article support */
    main {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1rem;
        font-family: system-ui, sans-serif;
        color: #1a202c;
    }
    header { margin-bottom: 3rem; text-align: center; }
    h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    
    .experiment-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .card {
        padding: 1.5rem;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        position: relative;
    }

    .badge {
        font-size: 0.7rem;
        font-weight: bold;
        padding: 0.25rem 0.5rem;
        background: #edf2f7;
        border-radius: 4px;
        text-transform: uppercase;
        color: #4a5568;
    }

    .button {
        display: inline-block;
        margin-top: 1rem;
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
    }

    .bot-links {
        border-top: 1px solid #e2e8f0;
        padding-top: 2rem;
        text-align: center;
        font-size: 0.9rem;
        color: #718096;
    }

    .bot-links a { color: #2563eb; margin: 0 0.5rem; text-decoration: none; }
</style>