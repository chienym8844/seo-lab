---
// src/components/AnswerCapsule.astro
// These are the "inputs" for your component
const { question, answer } = Astro.props;
---

<div class="answer-capsule-container" data-geo-entity="answer-block">
  <div class="question-header">
    <span class="icon">❓</span>
    <h2 class="question-text">{question}</h2>
  </div>
  
  <div class="answer-body">
    <p class="bluf-label"><strong>Quick Answer (TL;DR):</strong></p>
    <div class="answer-content">
      {answer}
    </div>
  </div>
</div>

<style>
  .answer-capsule-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background-color: #f8fafc;
    border: 2px solid #e2e8f0;
    border-left: 6px solid #2563eb; /* Blue accent to signal importance to crawlers */
    border-radius: 8px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .question-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .question-text {
    margin: 0;
    font-size: 1.25rem;
    color: #1e293b;
    font-weight: 700;
  }

  .bluf-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .answer-content {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #334155;
    font-weight: 500;
  }
</style>